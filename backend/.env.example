# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=mysql://user:password@localhost:3306/invoiceportal

# Session
SESSION_SECRET=change-this-to-a-random-secret

# Default tenant
DEFAULT_TENANT_KEY=default

# Futursoft B2C Authentication
FS_B2C_CLIENT_ID=your-b2c-client-id
FS_B2C_SCOPE=openid offline_access your-b2c-client-id
FS_AUTH_MOCK=false

# Futursoft API (default, can be overridden per tenant in tenant_settings)
FS_API_BASE_URL=https://api.futursoft.net
FS_WS_API_BASE_URL=https://ws-api.futursoft.net
FS_SUBSCRIPTION_KEY=your-subscription-key
FS_MOCK_API=false
FS_DEBUG=false

# Futursoft Sales API (supplier number lookup)
# Used to resolve Futursoft supplier numbers on invoice approval
FS_SALES_API_BASE_URL=https://api.autofutur.net:37999

# File Storage
# Leave S3_BUCKET unset to use local disk storage (backend/uploads/).
# Set S3_BUCKET to enable S3-compatible cloud storage (AWS S3 or Cloudflare R2).
#
# --- Cloudflare R2 ---
# S3_BUCKET=your-r2-bucket-name
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your-r2-access-key-id
# S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_PRESIGN_EXPIRY_SEC=3600
#
# --- Amazon S3 ---
# S3_BUCKET=your-s3-bucket-name
# S3_REGION=eu-west-1
# S3_ACCESS_KEY_ID=your-aws-access-key-id
# S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
# S3_PRESIGN_EXPIRY_SEC=3600

# Document Processing
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_RETRY_MODEL=gpt-4o

# CostPocket OCR fallback (optional)
COSTPOCKET_API_URL=
COSTPOCKET_API_KEY=

# Email Inbox Polling
EMAIL_POLL_ENABLED=true
EMAIL_POLL_INTERVAL_MS=300000
