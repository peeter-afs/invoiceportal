# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=mysql://user:password@localhost:3306/invoiceportal

# Session
SESSION_SECRET=change-this-to-a-random-secret

# Default tenant
DEFAULT_TENANT_KEY=default

# Futursoft B2C Authentication
FS_B2C_CLIENT_ID=your-b2c-client-id
FS_B2C_SCOPE=openid offline_access your-b2c-client-id
FS_AUTH_MOCK=false

# Futursoft API (default, can be overridden per tenant in tenant_settings)
FS_API_BASE_URL=https://api.futursoft.net
FS_WS_API_BASE_URL=https://ws-api.futursoft.net
FS_SUBSCRIPTION_KEY=your-subscription-key
FS_MOCK_API=false
FS_DEBUG=false

# Document Processing
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# CostPocket OCR fallback (optional)
COSTPOCKET_API_URL=
COSTPOCKET_API_KEY=

# Email Inbox Polling
EMAIL_POLL_ENABLED=true
EMAIL_POLL_INTERVAL_MS=300000
